# ── Frontend environment variables ──────────────────────────────────────────
# Copy this file to .env.local (local dev) or set as environment variables on
# DigitalOcean App Platform / Droplet.
#
# NEXT_PUBLIC_* variables are baked into the browser bundle at build time.
# Update NEXT_PUBLIC_API_URL before building for production.

# Local development
NEXT_PUBLIC_API_URL=http://localhost:8000

# DigitalOcean production example:
# NEXT_PUBLIC_API_URL=https://api.your-do-app.ondigitalocean.app
